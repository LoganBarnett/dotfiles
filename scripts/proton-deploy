#!/usr/bin/env bash

set -euo pipefail

# See some quirks to this process here:
# https://discourse.nixos.org/t/remote-nixos-rebuild-works-with-build-but-not-with-switch/34741
#
# The derivation that wraps this script patches nixos-rebuild to copy the build
# closure using ssh-ng:// rather than ssh://.  The legacy ssh:// protocol pipes
# NAR data through nix-store --import over SSH, which fails intermittently with
# "Bad file descriptor" when transferring many paths.  ssh-ng:// uses the Nix
# daemon protocol and is persistent and reliable.
#
# --use-substitutes passes -s to nix copy, instructing the build host to fetch
# paths it's missing from its own substituters (cache.nixos.org) rather than
# requiring this machine to push every path.  Without this, any path not
# locally present (e.g. a Gemfile.lock fetched only from cache, not in this
# machine's store) causes a hard failure.

# Allow for any verb.  "switch" is typical - it builds and activates the system
# derivation, and also installs the bootloader.  "test" will build and activate
# the system derivation, but won't add it to the bootloader.  This means the
# derivation will be not be loaded on reboot - the prior activation will be used
# instead.  There is also "boot", which just installs the boot loader.
verb="$1"
host="$2"
shift 2

# Look up the deploy type for this host from the flake's hostSystems output.
# This maps every host identifier to "darwin" or "nixos" without evaluating any
# full system configuration.  Let errors propagate (set -e) so misconfiguration
# is visible instead of silently falling through to the wrong deploy path.
deploy_type=$(nix eval --raw ".#hostSystems.\"${host}\"")

if [ "$deploy_type" = "darwin" ]; then
  # darwin-rebuild does not support --target-host (PR #1631 pending upstream),
  # so we build the system derivation locally, copy the closure to the remote
  # host, and run its activate script over SSH.
  if [ "$verb" != "switch" ]; then
    echo "error: darwin hosts only support the 'switch' verb (got '$verb')" >&2
    exit 1
  fi
  # Evaluate locally to get the derivation path, then copy the derivation
  # (recipe, not built output) to the remote and build there.  This mirrors
  # the NixOS path's --build-host behavior and avoids store-signing issues
  # that arise when pushing locally-built outputs.
  echo "Evaluating darwin configuration for $host..." >&2
  drv=$(nix path-info --derivation ".#darwinConfigurations.${host}.system" \
    --accept-flake-config)
  echo "Copying derivation to $host.proton..." >&2
  nix copy --derivation --to "ssh-ng://${host}.proton" "$drv"
  echo "Building on $host.proton..." >&2
  # shellcheck disable=SC2029
  system=$(ssh "$host.proton" nix build "$drv" \
    --no-link --print-out-paths --accept-flake-config)
  echo "Activating on $host.proton..." >&2
  # shellcheck disable=SC2029
  ssh "$host.proton" sudo "$system/activate"
else
  # --fast is the same as --no-build-nix which is "useful you call nixos-rebuild
  # frequently" but it also makes the difference between working and not working.
  # In this case if `--fast` is omitted, we see:
  # /nix/store/f12m00gy5s976qm6p4xmcv8mkvc24an3-nixos-rebuild/bin/nixos-rebuild: line 432: /nix/store/ssqdazslv2wjpybnk0pjwnpq0dfpa6q2-coreutils-9.5/bin/mktemp: cannot execute binary file: Exec format error
  # See
  # https://discourse.nixos.org/t/deploy-nixos-configurations-on-other-machines/22940/23
  # for more oddities on the topic.
  nixos-rebuild \
    "$verb" \
    --flake '.#'"$host" \
    --target-host "$host.proton" \
    --build-host "$host.proton" \
    --use-remote-sudo \
    --use-substitutes \
    --accept-flake-config \
    --fast \
    "$@"
fi
