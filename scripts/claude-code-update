#!/usr/bin/env bash

################################################################################
# Updates static.nix with the new version and per-platform hashes for
# claude-code.
#
# Claude Code 2.1.x ships as a native binary via platform-specific npm
# packages (e.g. @anthropic-ai/claude-code-darwin-arm64).  We fetch each
# platform tarball and compute its hash for use by the overlay.
################################################################################

set -euo pipefail

repo_root="$PWD"

# Get latest version from npm.
version="$(curl --location --silent \
  https://registry.npmjs.org/@anthropic-ai/claude-code \
    | jq --raw-output '.["dist-tags"].latest'
)"

echo "Version: ${version}"

# Platform suffixes that correspond to Nix system identifiers.
declare -A platforms=(
  [aarch64-darwin]=darwin-arm64
  [x86_64-darwin]=darwin-x64
  [x86_64-linux]=linux-x64
  [aarch64-linux]=linux-arm64
)

declare -A hashes

for nix_system in "${!platforms[@]}"; do
  suffix="${platforms[$nix_system]}"
  url="https://registry.npmjs.org/@anthropic-ai/claude-code-${suffix}/-/claude-code-${suffix}-${version}.tgz"
  echo "Fetching ${nix_system} (${suffix})..."
  hash_32="$(nix-prefetch-url --type sha256 --unpack "${url}")"
  hash_sri="$(nix hash to-sri --type sha256 "${hash_32}")"
  hashes[${nix_system}]="${hash_sri}"
  echo "  ${nix_system}: ${hash_sri}"
done

# Update static.nix.
cd "${repo_root}"

nix-editor \
  static.nix \
  'claude-code.version' \
  --val "\"${version}\"" \
  --inplace

for nix_system in "${!hashes[@]}"; do
  nix-editor \
    static.nix \
    "claude-code.${nix_system}.hash" \
    --val "\"${hashes[$nix_system]}\"" \
    --inplace
done

# Final formatting pass.
nix-editor \
  static.nix \
  'claude-code.version' \
  --val "\"${version}\"" \
  --inplace \
  --format

echo "Done.  Updated static.nix to claude-code ${version}."
