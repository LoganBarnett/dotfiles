#!/usr/bin/env bash

################################################################################
# Automatically connect to GlobalProtect VPN using headless browser automation.
# Handles SSO authentication and TOTP/MFA challenges automatically.
################################################################################

set -e

# GNU inetutils ifconfig (from Nix) silently returns empty output for macOS
# interface addresses.  Use the macOS system ifconfig explicitly.
IFCONFIG=/sbin/ifconfig

# Configuration
GP_SERVER="${GP_SERVER:-}"
GP_GATEWAY="${GP_GATEWAY:-}"
GP_USERNAME="${GP_USERNAME:-}"
GP_PASS_ENTRY="${GP_PASS_ENTRY:-${ORG_NAME}}"
GP_TOTP_ENTRY="${GP_TOTP_ENTRY:-${ORG_NAME}-totp}"
GP_LOG_DIR="${GP_LOG_DIR:-$HOME/.local/share/gpclient/logs}"

# Parse arguments
VERBOSE=""
CLEAN=false

while [[ $# -gt 0 ]]; do
  case $1 in
    -v|--verbose)
      VERBOSE="-v"
      shift
      ;;
    -vv|--very-verbose)
      VERBOSE="-vv"
      shift
      ;;
    --clean)
      CLEAN=true
      shift
      ;;
    -h|--help)
      echo "Usage: gp-connect-auto [OPTIONS]"
      echo ""
      echo "Automatically connect to GlobalProtect VPN with headless authentication."
      echo ""
      echo "Options:"
      echo "  --clean               Clear cached authentication cookies"
      echo "  -v, --verbose         Enable verbose output"
      echo "  -vv, --very-verbose   Enable trace output"
      echo "  -h, --help            Show this help message"
      echo ""
      echo "Environment Variables:"
      echo "  GP_SERVER             Portal server URL (required)"
      echo "  GP_USERNAME           VPN username (email address) (required)"
      echo "  ORG_NAME              Organization name (required for default pass entries)"
      echo "  GP_PASS_ENTRY         Pass entry for password (default: \$ORG_NAME)"
      echo "  GP_TOTP_ENTRY         Pass entry for TOTP (default: \$ORG_NAME-totp)"
      echo ""
      echo "Credentials are retrieved from 'pass':"
      echo "  Password: pass show \$GP_PASS_ENTRY"
      echo "  TOTP:     pass otp \$GP_TOTP_ENTRY"
      exit 0
      ;;
    *)
      echo "Error: Unknown option $1"
      echo "Use -h or --help for usage information"
      exit 1
      ;;
  esac
done

# Validate environment
if [ -z "$GP_SERVER" ]; then
  echo "Error: GP_SERVER environment variable is not set"
  exit 1
fi

if [ -z "$GP_USERNAME" ]; then
  echo "Error: GP_USERNAME environment variable is not set"
  exit 1
fi

if [ -z "$ORG_NAME" ]; then
  echo "Error: ORG_NAME environment variable is not set"
  exit 1
fi

# Check if pass is available
if ! command -v pass &> /dev/null; then
  echo "Error: 'pass' command not found"
  exit 1
fi

# Create log directory
mkdir -p "$GP_LOG_DIR"

echo "============================================================"
echo "GlobalProtect Automatic Connection"
echo "============================================================"
echo "Server:   $GP_SERVER"
echo "User:     $GP_USERNAME"
echo "Password: Retrieved from pass ($GP_PASS_ENTRY)"
echo "TOTP:     Generated from pass otp ($GP_TOTP_ENTRY)"
echo ""

# Retrieve credentials
echo "Retrieving credentials from pass..."
PASSWORD=$(pass show "$GP_PASS_ENTRY" | head -1)
if [ -z "$PASSWORD" ]; then
  echo "Error: Failed to retrieve password from pass"
  exit 1
fi
echo "✓ Password retrieved"

TOTP_CODE=$(pass otp "$GP_TOTP_ENTRY")
if [ -z "$TOTP_CODE" ]; then
  echo "Error: Failed to retrieve TOTP code from pass"
  exit 1
fi
echo "✓ TOTP code generated: $TOTP_CODE"
echo ""

# Build gpclient command
GP_CMD="gpclient connect --browser remote $VERBOSE"
if [ "$CLEAN" = true ]; then
  GP_CMD="$GP_CMD --clean"
fi
if [ -n "$GP_GATEWAY" ]; then
  GP_CMD="$GP_CMD --gateway \"$GP_GATEWAY\""
fi
# Submit the HIP (Host Integrity Protection) report required by the corporate
# VPN gateway to unlock data-plane traffic.  GP_CSD_WRAPPER is the absolute
# nix-store path set by the derivation at build time; fall back to the --hip
# default-wrapper flag when the variable is absent (e.g. in ad-hoc invocations).
if [ -n "${GP_CSD_WRAPPER:-}" ] && [ -f "$GP_CSD_WRAPPER" ]; then
  GP_CMD="$GP_CMD --csd-wrapper \"$GP_CSD_WRAPPER\""
else
  GP_CMD="$GP_CMD --hip"
fi
# Use custom macOS vpnc-script if available
if [ -n "$GP_VPNC_SCRIPT" ] && [ -f "$GP_VPNC_SCRIPT" ]; then
  GP_CMD="$GP_CMD --script \"$GP_VPNC_SCRIPT\""
fi
GP_CMD="$GP_CMD \"$GP_SERVER\""

echo "Starting gpclient in remote browser mode with PTY..."
echo "Running: $GP_CMD"
echo ""

# ── Pre-VPN state capture ─────────────────────────────────────────────
# Save the physical interface state BEFORE gpclient strips en10's IPv4.
# gpclient calls 'ipconfig set <iface> NONE' before firing vpnc-script
# pre-init, so pre-init cannot capture this state itself.  The vpnc-script
# connect case reads these files as a fallback.
echo "Saving pre-VPN network state..."
# Each pipeline is guarded with || true because writeShellApplication sets
# pipefail: head -1 causes SIGPIPE on awk (exit 141), which pipefail
# propagates, and set -e kills the script.
_PV_IF=$(route -n get default 2>/dev/null | awk '/interface:/ {print $2; exit}') || true
_PV_GW=$(route -n get default 2>/dev/null | \
  awk '/gateway:/ && $2 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/ {print $2; exit}') || true
_PV_IP=$("$IFCONFIG" "${_PV_IF:-}" 2>/dev/null | \
  awk '/inet [0-9]/ {print $2}' | head -1) || true
_PV_MASK=$("$IFCONFIG" "${_PV_IF:-}" 2>/dev/null | \
  awk '/inet [0-9]/ {print $4}' | head -1) || true
echo "  interface=${_PV_IF:-none} ip=${_PV_IP:-none} mask=${_PV_MASK:-none} gw=${_PV_GW:-none}"

if [ -n "$_PV_IF" ] && [ -n "$_PV_IP" ] && [ -n "$_PV_MASK" ]; then
  printf '%s %s %s %s\n' "$_PV_IF" "$_PV_IP" "$_PV_MASK" "${_PV_GW:-}" \
    > /var/run/vpnc-pre-vpn-state
  echo "  Saved to /var/run/vpnc-pre-vpn-state"

  # Save DHCP DNS nameservers.  The || true guards against pipefail: grep
  # returns 1 when no lines match, which would kill the script under set -e.
  _PV_DNS=$(printf 'show State:/Network/Service/DHCP-%s/DNS\nquit\n' \
    "$_PV_IF" | scutil 2>/dev/null | \
    awk '$1 ~ /^[0-9]+$/ {print $3}' | \
    grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | tr '\n' ' ' | \
    sed 's/[[:space:]]*$//') || true
  if [ -n "$_PV_DNS" ]; then
    echo "$_PV_DNS" > /var/run/vpnc-pre-vpn-dns
    echo "  Saved pre-VPN DNS: $_PV_DNS"
  fi

  # Save network service name for networksetup.  The || true guards against
  # pipefail if networksetup or awk returns non-zero.
  _PV_SVC=$(networksetup -listnetworkserviceorder 2>/dev/null | \
    awk -v dev="$_PV_IF" '
      /^\(Hardware Port:/ {
        if (index($0, "Device: " dev) > 0) {
          match(prev, /^\([0-9]+\) /)
          print substr(prev, RLENGTH + 1)
        }
      }
      { prev = $0 }
    ') || true
  if [ -n "$_PV_SVC" ]; then
    echo "$_PV_SVC" > /var/run/vpnc-pre-vpn-service
    echo "  Saved pre-VPN network service: $_PV_SVC"
  fi
else
  echo "  WARNING: Could not capture pre-VPN state (IP or mask missing)"
fi
echo ""

# Use Python PTY wrapper to run gpclient
# It will handle authentication automatically
# Pass the actual script path, not the function name
gp-connect-pty.py "$GP_CMD" "$GP_USERNAME" "$PASSWORD" "$TOTP_CODE" "$AUTH_SCRIPT"
GPCLIENT_EXIT=$?

if [ $GPCLIENT_EXIT -eq 0 ]; then
  echo ""
  echo "============================================================"
  echo "✓ VPN connection established successfully!"
  echo "============================================================"
  echo ""
  echo "Check connection status:"
  echo "  ifconfig gpd0"
  echo ""
  exit 0
else
  echo ""
  echo "============================================================"
  echo "✗ VPN connection failed"
  echo "============================================================"
  echo ""
  echo "Check logs in: $GP_LOG_DIR"
  echo "Check screenshots in: /tmp/gp-auth-*.png"
  exit 1
fi
