#!/usr/bin/env bash
################################################################################
# Fix GlobalProtect VPN DNS scoping for macOS.
# This script creates /etc/resolver entries to ensure VPN domains are resolved
# using the VPN DNS servers, not the local DNS. This is more reliable than
# scutil-based configuration which can be overridden by network changes.
################################################################################

set -e

# GNU inetutils ifconfig (from Nix) silently returns empty output for macOS
# interface addresses.  Use the macOS system ifconfig explicitly.
IFCONFIG=/sbin/ifconfig

# Find the VPN tunnel interface: prefer UP utun interfaces with a 10.89.x IP,
# then any UP utun with a 10.x IP.  The old code picked the first match in
# ifconfig order, which could be a stale not-UP interface from a previous
# session.
VPN_IF=""
for _iface_line in $("$IFCONFIG" | awk '/^utun/{print $1}' | tr -d ':'); do
  "$IFCONFIG" "$_iface_line" 2>/dev/null | head -1 | grep -q "UP" || continue
  _ip=$("$IFCONFIG" "$_iface_line" 2>/dev/null | awk '/inet 10\.89\./ {print $2}' | head -1)
  if [ -n "$_ip" ]; then
    VPN_IF="$_iface_line"
    break
  fi
done
# Fallback: any UP utun with a 10.x IP.
if [ -z "$VPN_IF" ]; then
  for _iface_line in $("$IFCONFIG" | awk '/^utun/{print $1}' | tr -d ':'); do
    ifconfig "$_iface_line" 2>/dev/null | head -1 | grep -q "UP" || continue
    _ip=$(ifconfig "$_iface_line" 2>/dev/null | awk '/inet 10\./ {print $2}' | head -1)
    if [ -n "$_ip" ]; then
      VPN_IF="$_iface_line"
      break
    fi
  done
fi

if [ -z "$VPN_IF" ]; then
  echo "Error: No VPN tunnel interface found"
  exit 1
fi

echo "Found VPN interface: $VPN_IF"

# Extract DNS configuration from scutil.
DNS_CONFIG=$(scutil --dns)

# Extract VPN DNS servers (internal IPs in 10.x range, excluding the VPN tunnel
# IP range itself).
mapfile -t VPN_DNS_SERVERS < <(echo "$DNS_CONFIG" | \
  grep "nameserver\[" | \
  awk '{print $3}' | \
  grep "^10\." | \
  grep -v "^10\.89\." | \
  sort -u)

# Extract VPN-specific search domains (exclude local domains like .local,
# .proton, etc.).
mapfile -t VPN_SEARCH_DOMAINS < <(echo "$DNS_CONFIG" | \
  grep -E "domain\[|search domain\[" | \
  awk '{print $4}' | \
  grep -E "\.(pvt|hmco\.com|hmhco\.com|hmhpub\.com|heinemann\.com|hegn\.us)$" | \
  sort -u)

if [ ${#VPN_DNS_SERVERS[@]} -eq 0 ]; then
  echo "Error: No VPN DNS servers found in current configuration"
  exit 1
fi

if [ ${#VPN_SEARCH_DOMAINS[@]} -eq 0 ]; then
  # The VPN server sent no CISCO_SPLIT_DNS domains and scutil has no domain
  # hints.  Fall back to the known corporate TLDs so that VPN DNS is scoped
  # correctly.  Without this, macOS uses the VPN DNS servers globally (since
  # scutil ServerAddresses without SupplementalMatchDomains applies to all
  # queries), breaking public-domain resolution (e.g. yahoo.com returns
  # NXDOMAIN from the corporate resolver).
  VPN_SEARCH_DOMAINS=(
    americas.nwea.pvt
    nwea.pvt
    nweacolo.pvt
    pubedu.hegn.us
    rpcsys.hmco.com
    sap2.hmhco.com
  )
  echo "No VPN search domains from scutil — using known corporate domains as fallback"
fi

echo "Found VPN DNS servers: ${VPN_DNS_SERVERS[*]}"
echo "Found VPN search domains: ${VPN_SEARCH_DOMAINS[*]}"

# Create resolver files for each VPN domain using privileged helper.
# The helper validates all inputs and only operates on /etc/resolver.
echo "Creating resolver configurations..."
for domain in "${VPN_SEARCH_DOMAINS[@]}"; do
  echo "Configuring resolver for $domain..."

  # Call privileged helper to create resolver file.  Use sudo so this script
  # can be run as a regular user; when already root (e.g. from vpnc-script)
  # sudo is a no-op.
  sudo dns-resolver-helper create-resolver "$domain" "${VPN_DNS_SERVERS[@]}"

  echo "  Created /etc/resolver/$domain"
done

# Flush DNS cache to apply changes.
echo "Flushing DNS cache..."
sudo dns-resolver-helper flush-cache

echo "DNS scoping configured successfully for ${#VPN_SEARCH_DOMAINS[@]} domains"
