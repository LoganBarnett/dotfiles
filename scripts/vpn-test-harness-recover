#!/usr/bin/env bash
################################################################################
# GP-specific teardown and non-disruptive network recovery.
#
#   1. Kills any running gpclient instance (by PID from lock file).
#   2. Kills vpnc-script watchdog processes.
#   3. Removes VPN routes (10.x private ranges, utun default, utun routes).
#   4. Clears scutil DNS and IPv4 entries injected by the vpnc-script.
#   5. Removes all /var/run/vpnc-* and gpclient state files.
#   6. Targeted network recovery: DHCP restore on active interfaces, DNS
#      override clear, /etc/resolver cleanup, DNS cache flush.
#
# Recovery deliberately avoids disabling/re-enabling network services
# (the old vpn-dns-recover approach) because that kills Claude Code's
# API streaming connection mid-recovery.
#
# No attempt is made to detect the current state; every step runs
# unconditionally so stale state can never cause a missed cleanup.
#
# Requires root (called via sudo from vpn-test-harness or run manually).
################################################################################

set -euo pipefail

# GNU inetutils ifconfig (from Nix) silently returns empty output for macOS
# interface addresses.  Use the macOS system ifconfig explicitly.
IFCONFIG=/sbin/ifconfig

if [ "$(id -u)" -ne 0 ]; then
  echo "Error: vpn-test-harness-recover must run as root" >&2
  exit 1
fi

echo "========================================================"
echo "vpn-test-harness-recover: GP-specific teardown"
echo "========================================================"
echo ""

# Show pre-recovery routing state for post-mortem diagnosis.
echo "Pre-recovery default route:"
route -n get default 2>&1 || echo "  (none)"
echo ""

# ---------------------------------------------------------------------------
# Step 1: Kill any running gpclient instance.
# ---------------------------------------------------------------------------
# gpclient must be gone before the next connect attempt; otherwise it reports
# "Another instance of the client is already running" and exits with code 1.
# Reading the PID from the lock file is more precise than pkill, and avoids
# accidentally killing unrelated processes.
GPCLIENT_LOCK="/var/run/gpclient.lock"
echo "Killing any running gpclient instance..."
if [ -f "$GPCLIENT_LOCK" ]; then
  GPC_PID=$(cat "$GPCLIENT_LOCK" 2>/dev/null || echo "")
  if [ -n "$GPC_PID" ] && kill -0 "$GPC_PID" 2>/dev/null; then
    echo "  Sending SIGKILL to gpclient PID $GPC_PID..."
    kill -9 "$GPC_PID" 2>/dev/null || true
    sleep 1
  fi
  rm -f "$GPCLIENT_LOCK"
  echo "  Removed gpclient lock file"
else
  echo "  (no gpclient lock file found)"
fi

# ---------------------------------------------------------------------------
# Step 1b: Kill vpnc-script watchdog processes.
# ---------------------------------------------------------------------------
# These bash subshells inherit the utun fd from gpclient.  They must be killed
# before the kernel can destroy the utun interface, otherwise the stale not-UP
# interface lingers and confuses the next session's TUNDEV detection.
echo "Killing vpnc-script watchdog processes..."
KILLED_WDOGS=0
for _wf in /var/run/vpnc-connect-watchdog.pid /var/run/vpnc-preinit-watchdog.pid; do
  if [ -f "$_wf" ]; then
    _WP=$(cat "$_wf" 2>/dev/null || echo "")
    if [ -n "$_WP" ] && kill -0 "$_WP" 2>/dev/null; then
      echo "  Sending SIGKILL to watchdog PID $_WP ($(basename "$_wf"))..."
      kill -9 "$_WP" 2>/dev/null || true
      KILLED_WDOGS=$((KILLED_WDOGS + 1))
    fi
    rm -f "$_wf"
  fi
done
echo "  Killed $KILLED_WDOGS watchdog process(es)"

# ---------------------------------------------------------------------------
# Step 1c: Explicitly delete known VPN private routes.
# ---------------------------------------------------------------------------
# The utun-interface scan below may miss WASCLONED host routes (gateway
# column shows link#N rather than utun).  Delete by destination to be safe.
echo "Removing known VPN private routes..."
route delete -net 10.0.0.0/8 2>/dev/null && echo "  Deleted 10.0.0.0/8" || \
  echo "  (no 10.0.0.0/8 route)"
route delete -net 172.16.0.0/12 2>/dev/null && echo "  Deleted 172.16.0.0/12" || \
  echo "  (no 172.16.0.0/12 route)"

# ---------------------------------------------------------------------------
# Step 2: Remove the current default route.
# ---------------------------------------------------------------------------
echo "Checking default route..."
_DEF_IF=$(route -n get default 2>/dev/null | awk '/interface:/ {print $2; exit}')
if [[ "${_DEF_IF:-}" == utun* ]]; then
  echo "  Default route via utun ($_DEF_IF) — deleting"
  route delete default 2>/dev/null || true
else
  echo "  Default route via ${_DEF_IF:-none} (physical) — keeping"
fi

# ---------------------------------------------------------------------------
# Step 2b: Remove any remaining utun-based routes.
# ---------------------------------------------------------------------------
echo "Removing utun routes from routing table..."
REMOVED=0
while true; do
  # Find any route whose gateway or interface column references a utun device.
  # WASCLONED host routes have gateway=link#N but interface=utunX ($6 or $NF).
  UTUN_ROUTE=$(netstat -rn -f inet 2>/dev/null | \
    awk '/^[0-9]/ && ($2 ~ /^utun/ || $NF ~ /^utun/) {print $1; exit}' || true)
  if [ -z "$UTUN_ROUTE" ]; then
    break
  fi
  if route delete "$UTUN_ROUTE" 2>/dev/null; then
    REMOVED=$((REMOVED + 1))
  else
    break
  fi
done
echo "  Removed $REMOVED utun route(s)"

# ---------------------------------------------------------------------------
# Step 3: Clear scutil DNS state injected by the vpnc-script.
# ---------------------------------------------------------------------------
echo "Clearing VPN DNS/IPv4 state from scutil..."
# Enumerate State:/Network/Service/utun*/{DNS,IPv4} entries and remove them.
while IFS= read -r key; do
  [ -z "$key" ] && continue
  printf 'remove %s\nquit\n' "$key" | scutil 2>/dev/null || true
  echo "  Removed scutil key: $key"
done < <(printf 'list\n' | scutil 2>/dev/null | \
  awk '/utun.*(DNS|IPv4)/ {print $4}' || true)
# Remove the synthetic VPN corporate DNS service (vpn-corp-dns).
printf 'remove State:/Network/Service/vpn-corp-dns/DNS\nremove State:/Network/Service/vpn-corp-dns/IPv4\nquit\n' \
  | scutil 2>/dev/null || true
echo "  Removed vpn-corp-dns service"
# Remove the synthetic public DNS service created during connect.
if [ -f /var/run/vpnc-public-dns-service ]; then
  _PUB_SVC=$(cat /var/run/vpnc-public-dns-service)
  printf 'remove State:/Network/Service/%s/DNS\nremove State:/Network/Service/%s/IPv4\nquit\n' \
    "$_PUB_SVC" "$_PUB_SVC" | scutil 2>/dev/null || true
  rm -f /var/run/vpnc-public-dns-service
  echo "  Removed synthetic public DNS service"
fi

# ---------------------------------------------------------------------------
# Step 4: Remove all VPN state files so the next session starts clean.
# ---------------------------------------------------------------------------
# Keep /var/run/vpnc-dns-domains for the recovery section below — it
# reads the file to clean up /etc/resolver entries, then removes it.
rm -f /var/run/vpnc-default-gateway \
      /var/run/vpnc-actual-tundev \
      /var/run/vpnc-vpn-gateway \
      /var/run/vpnc-pre-vpn-if \
      /var/run/vpnc-pre-vpn-state \
      /var/run/vpnc-pre-vpn-dns \
      /var/run/vpnc-pre-vpn-service \
      /var/run/gp-vpnc-script \
      /var/run/vpnc-connect-watchdog.pid \
      /var/run/vpnc-preinit-watchdog.pid
echo "Cleared VPN state files"

# ── Targeted network recovery (non-disruptive) ───────────────────────
# Unlike vpn-dns-recover, this does NOT disable/re-enable network
# services — that breaks Claude Code's API streaming connection.
echo ""
echo "Performing targeted network recovery..."

# Restore DHCP on active hardware interfaces.
while IFS= read -r _iface; do
  if "$IFCONFIG" "$_iface" 2>/dev/null | grep -q 'status: active'; then
    echo "  ipconfig set $_iface DHCP"
    ipconfig set "$_iface" DHCP 2>/dev/null || true
  fi
done < <(networksetup -listallhardwareports | awk '/^Device:/{print $2}')

# Wait for default route to come back.
echo "  Waiting for default route..."
for _w in $(seq 1 30); do
  if route -n get default >/dev/null 2>&1; then
    echo "  Default route restored after ${_w}s"
    break
  fi
  sleep 1
done

# Clear any explicit DNS overrides left by the vpnc-script.
# When dnsmasq is running, restore DNS to 127.0.0.1 so all tools
# continue resolving through dnsmasq.
if pgrep -x dnsmasq >/dev/null 2>&1; then
  _DNS_TARGET="127.0.0.1"
  echo "  dnsmasq running — restoring DNS to $_DNS_TARGET"
else
  _DNS_TARGET="Empty"
fi
while IFS= read -r _svc; do
  networksetup -setdnsservers "$_svc" "$_DNS_TARGET" 2>/dev/null || true
  networksetup -setsearchdomains "$_svc" Empty 2>/dev/null || true
done < <(networksetup -listallnetworkservices | tail -n +2)

# Clear dnsmasq VPN servers so corporate domains stop resolving after
# recovery.
if pgrep -x dnsmasq >/dev/null 2>&1; then
  : > /var/run/dnsmasq-vpn-servers.conf 2>/dev/null || true
  killall -HUP dnsmasq 2>/dev/null || true
  echo "  Cleared dnsmasq VPN servers"
fi

# Clean up /etc/resolver files created during VPN connect.
if [ -f /var/run/vpnc-dns-domains ]; then
  while IFS= read -r _dom; do
    [ -n "$_dom" ] && rm -f "/etc/resolver/$_dom"
  done < /var/run/vpnc-dns-domains
  rm -f /var/run/vpnc-dns-domains
fi

# Flush DNS cache.
dscacheutil -flushcache 2>/dev/null || true
killall -HUP mDNSResponder 2>/dev/null || true
echo "  DNS cache flushed"
echo "  Targeted recovery complete"

echo ""
echo "========================================================"
echo "vpn-test-harness-recover: done"
echo "========================================================"
