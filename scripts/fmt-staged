#!/usr/bin/env bash
# Format only staged files using treefmt, leaving unstaged edits alone.
root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only --diff-filter=d)
if [ -z "$staged" ]; then
  echo "No staged files." >&2
  exit 0
fi
cd "$root" || exit 1
# Pass paths NUL-delimited so names containing spaces are handled correctly.
# Disable errexit around treefmt: it exits non-zero when it modifies files,
# which would abort the script before re-staging if set -e were active.
set +e
git diff --cached --name-only --diff-filter=d -z | xargs -0 treefmt
set -e
# Re-stage the formatted files so the commit includes the formatted versions.
git diff --cached --name-only --diff-filter=d -z | xargs -0 git add
