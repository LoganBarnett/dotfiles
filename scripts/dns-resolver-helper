#!/usr/bin/env bash
################################################################################
# Privileged helper for managing /etc/resolver DNS configuration.
# This script validates all inputs and only operates on /etc/resolver.
# Designed to be called via sudo NOPASSWD for automated VPN DNS configuration.
################################################################################

set -e

# Validate that we're running as root
if [ "$(id -u)" -ne 0 ]; then
  echo "Error: This script must be run as root" >&2
  exit 1
fi

# Validate command
COMMAND="$1"
shift

case "$COMMAND" in
  create-resolver)
    # Usage: dns-resolver-helper create-resolver <domain> <server1> [server2] ...
    DOMAIN="$1"
    shift

    # Validate domain name (alphanumeric, dots, hyphens only)
    if ! [[ "$DOMAIN" =~ ^[a-zA-Z0-9.-]+$ ]]; then
      echo "Error: Invalid domain name: $DOMAIN" >&2
      exit 1
    fi

    # Validate at least one DNS server provided
    if [ $# -eq 0 ]; then
      echo "Error: At least one DNS server required" >&2
      exit 1
    fi

    # Validate all DNS servers are valid IP addresses
    for server in "$@"; do
      if ! [[ "$server" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        echo "Error: Invalid DNS server IP: $server" >&2
        exit 1
      fi
    done

    # Create /etc/resolver if it doesn't exist
    mkdir -p /etc/resolver

    # Create resolver file
    RESOLVER_FILE="/etc/resolver/$DOMAIN"
    {
      for server in "$@"; do
        echo "nameserver $server"
      done
    } > "$RESOLVER_FILE"

    echo "Created $RESOLVER_FILE"
    ;;

  flush-cache)
    # Flush DNS cache
    dscacheutil -flushcache
    killall -HUP mDNSResponder 2>/dev/null || true
    echo "DNS cache flushed"
    ;;

  *)
    echo "Error: Unknown command: $COMMAND" >&2
    echo "Usage: dns-resolver-helper {create-resolver|flush-cache}" >&2
    exit 1
    ;;
esac
