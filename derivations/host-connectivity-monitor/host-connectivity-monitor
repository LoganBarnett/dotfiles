#!/usr/bin/env bash
set -euo pipefail

# Monitor a list of hosts and sound a local alert after any have been
# continuously unreachable for DOWNTIME_THRESHOLD seconds.
#
# Reachability is tested with ping, which covers both DNS resolution and ICMP
# in a single call.  Every host must respond to suppress the alarm.
#
# Usage: host-connectivity-monitor HOST [HOST ...]
#
# Environment variables:
#   DOWNTIME_THRESHOLD  seconds before alerting (default: 300)
#   CHECK_INTERVAL      seconds between polls (default: 15)

DOWNTIME_THRESHOLD="${DOWNTIME_THRESHOLD:-300}"
CHECK_INTERVAL="${CHECK_INTERVAL:-15}"

if [[ $# -eq 0 ]]; then
    echo "Usage: $(basename "$0") HOST [HOST ...]" >&2
    exit 1
fi

hosts=("$@")
down_since=""
alert_pid=""

# Sets reachable_hosts and unreachable_hosts arrays from the global hosts list.
# Returns 0 if at least one host responded, 1 if none did.
check_all_hosts() {
    reachable_hosts=()
    unreachable_hosts=()
    for host in "${hosts[@]}"; do
        # -t 2: macOS ping timeout flag (seconds).  -c 1: single probe.
        if ping -c 1 -t 2 "${host}" >/dev/null 2>&1; then
            reachable_hosts+=("${host}")
        else
            unreachable_hosts+=("${host}")
        fi
    done
    [[ "${#reachable_hosts[@]}" -gt 0 ]]
}

stop_alert() {
    if [[ -n "${alert_pid}" ]]; then
        kill "${alert_pid}" 2>/dev/null || true
        wait "${alert_pid}" 2>/dev/null || true
        alert_pid=""
    fi
}

trap 'stop_alert; exit 0' INT TERM

echo "Monitoring: ${hosts[*]}"
echo "Alert threshold: ${DOWNTIME_THRESHOLD}s, check interval: ${CHECK_INTERVAL}s"

reachable_hosts=()
unreachable_hosts=()

while true; do
    check_all_hosts || true
    if [[ "${#unreachable_hosts[@]}" -eq 0 ]]; then
        if [[ -n "${down_since}" ]]; then
            echo "$(date): all hosts reachable again — stopping alert."
            stop_alert
            down_since=""
        else
            echo "$(date): ok — up=${reachable_hosts[*]}"
            # Run in background with a timeout so a stalled audio device
            # (e.g. screen locked) cannot block the monitor loop.
            timeout "${CHECK_INTERVAL}" sonification-test healthy &
        fi
    else
        now="$(date +%s)"
        if [[ -z "${down_since}" ]]; then
            down_since="${now}"
            echo "$(date): unreachable: ${unreachable_hosts[*]}"
        fi
        downtime=$(( now - down_since ))
        if [[ "${downtime}" -ge "${DOWNTIME_THRESHOLD}" ]] && [[ -z "${alert_pid}" ]]; then
            echo "$(date): ${downtime}s continuous downtime — starting alert."
            alert-me-locally &
            alert_pid="$!"
        fi
    fi
    sleep "${CHECK_INTERVAL}"
done
